# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Razorpay ──────────────────────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Gmail OTP Authentication ──────────────────────────────────
# The Gmail account that sends OTP emails
GMAIL_USER=dremakcaterers@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to generate: Google Account → Security → 2-Step Verification → App Passwords
# It looks like: xxxx xxxx xxxx xxxx (16 chars, spaces are optional)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# JWT Secret — must be at least 32 random characters
# Generate one by running: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters

# ── Access Control ────────────────────────────────────────────
# Comma-separated list of Gmail addresses allowed to log in
# Only these emails will receive an OTP and gain access
ALLOWED_EMAILS=yourname@gmail.com,anotherperson@gmail.com

# ── Server (optional) ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# For production (Vercel), set:
# NODE_ENV=production
# CLIENT_ORIGIN=https://your-vercel-domain.vercel.app
